{
  "name": "claudeclaw",
  "version": "1.1.0",
  "description": "Your personal Claude Code assistant, delivered to your phone via Telegram",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:session2": "node test-session2-harden.mjs && bash scripts/session2-endpoint-check.sh",
    "test:notification": "node test-notification.mjs",
    "test:memory": "tsx scripts/test-memory-v2.ts && tsx scripts/test-consolidation.ts && tsx scripts/test-semantic-search.ts",
    "test:agents": "tsx scripts/battle-10-turns.ts && tsx scripts/battle-test-all-agents.ts",
    "migrate": "tsx scripts/migrate.ts",
    "setup": "tsx scripts/setup.ts",
    "status": "tsx scripts/status.ts",
    "agent:create": "bash scripts/agent-create.sh",
    "agent:start": "node dist/index.js --agent",
    "uninstall": "bash scripts/uninstall.sh",
    "build:warroom-client": "esbuild warroom/client.js --bundle --outfile=warroom/client.bundle.js --format=iife --global-name=PipecatWarRoom"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.34",
    "@anthropic-ai/sdk": "^0.32.1",
    "@extractus/article-extractor": "^8.0.20",
    "@google/genai": "^1.44.0",
    "@hono/node-server": "^1.19.9",
    "@slack/web-api": "^7.14.1",
    "better-sqlite3": "^11.8.1",
    "cron-parser": "^5.5.0",
    "docx": "^8.5.0",
    "grammy": "^1.34.0",
    "hono": "^4.12.3",
    "js-yaml": "^4.1.1",
    "marked": "^12.0.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "puppeteer": "^24.41.0",
    "qrcode-terminal": "^0.12.0",
    "twilio": "^6.0.0",
    "whatsapp-web.js": "^1.34.6"
  },
  "devDependencies": {
    "@pipecat-ai/client-js": "^1.7.0",
    "@pipecat-ai/websocket-transport": "^1.6.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@vitest/coverage-v8": "^2.0.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "vitest": {
    "environment": "node",
    "include": [
      "src/**/*.test.ts"
    ]
  }
}
